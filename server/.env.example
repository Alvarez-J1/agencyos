PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/agencyos
JWT_SECRET=replace-with-a-strong-random-secret
# In production, CLIENT_ORIGIN is required and must match the exact frontend origin.
# Use a comma-separated list for multiple production frontends, for example:
# CLIENT_ORIGIN=https://app.example.com,https://admin.example.com
CLIENT_ORIGIN=http://localhost:4200
NODE_ENV=development
REQUEST_BODY_LIMIT=100kb
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=20
SIGNUP_RATE_LIMIT_MAX=10
